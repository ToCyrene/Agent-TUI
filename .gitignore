# --- 依赖与构建产物 ---
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# --- 执行文件与二进制文件 ---
# 忽略所有操作系统生成的二进制文件
*.exe
*.dll
*.so
*.dylib
# 忽略 Node.js 编译的 C++ 插件
build/Release/
*.node

# --- 环境变量与私密信息 ---
# 必须忽略，防止泄露 API Keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# --- 操作系统与编辑器 ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- 临时文件与日志 ---
logs
*.log
npm-debug.log*
pnpm-debug.log*
.history/
.temp/
.tmp/

# --- 允许上传的文件 (白名单思想) ---
# 明确允许上传的文件类型/文件夹
!package.json
!package-lock.json
!CLAUDE.md
!IMPL.md
!.claude
!.claudeignore
!src/
!config/
!.env.example